# ─────────────────────────────────────────────────────────────
#  NBOOG SACCO — Environment Variables
#  Copy this file to .env (local dev) or paste into Vercel.
#
#  Recommended free PostgreSQL providers:
#    • Neon      → https://neon.tech   (DATABASE_URL + DIRECT_URL both provided)
#    • Supabase  → https://supabase.com
#    • Railway   → https://railway.app
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Pooled connection URL (used by Prisma in serverless)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&pgbouncer=true"

# Direct (non-pooled) URL — required for migrations / db push
# On Neon: same host but without &pgbouncer=true
# On Supabase: port 5432 direct connection string
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── Authentication ────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="replace-with-64-byte-random-secret-min-256-bits"

# Cookie name (can leave as default)
SESSION_COOKIE_NAME="nboog_session"

# ── Application ───────────────────────────────────────────────
APP_NAME="NBOOG SACCO"

# Your Vercel deployment URL (no trailing slash)
APP_URL="https://your-project.vercel.app"

NODE_ENV="production"

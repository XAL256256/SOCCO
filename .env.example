# Copy to .env for local dev. On Vercel, only DATABASE_URL is required.

# PostgreSQL (Neon free tier: create project → copy connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Optional — omit on Vercel; we derive a stable secret from DATABASE_URL automatically.
# Set explicitly if you rotate DB URL but want sessions to stay valid.
# JWT_SECRET="paste-openssl-rand-hex-64-here"

SESSION_COOKIE_NAME="nboog_session"
APP_NAME="NBOOG SACCO"
APP_URL="http://localhost:3000"
